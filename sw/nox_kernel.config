# Minimal NoX Linux kernel config
# Base: RISC-V 64-bit, Sv39 MMU, NS16550 UART, CLINT/PLIC, embedded initramfs

# Architecture
CONFIG_RISCV=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_PAGE_OFFSET=0xffffaf8000000000
CONFIG_ARCH_FLATMEM_ENABLE=y

# Minimal platform support
CONFIG_SOC_VIRT=y

# Timers
CONFIG_CLINT_TIMER=y
CONFIG_RISCV_TIMER=y

# Interrupt controller
CONFIG_RISCV_PLIC=y
CONFIG_RISCV_INTC=y

# SBI
CONFIG_RISCV_SBI=y
CONFIG_RISCV_SBI_V01=y

# Kernel features
CONFIG_SMP=n
CONFIG_SMP_POSSIBLE=n
CONFIG_CMDLINE_BOOL=n
CONFIG_HZ_100=y

# Memory
CONFIG_PHYSICAL_START=0x80000000
CONFIG_PHYSICAL_ALIGN=0x200000

# Serial
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_OF_PLATFORM=y
CONFIG_SERIAL_EARLYCON_RISCV_SBI=y

# Filesystems - minimal
CONFIG_TMPFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y

# Initramfs
CONFIG_BLK_DEV_INITRD=y
CONFIG_INITRAMFS_SOURCE="/home/phckopper/Projects/nox/sw/initramfs"
CONFIG_INITRAMFS_ROOT_UID=0
CONFIG_INITRAMFS_ROOT_GID=0

# Disable unneeded subsystems
CONFIG_NETWORK_FILESYSTEMS=n
CONFIG_NET=n
CONFIG_WLAN=n
CONFIG_WIRELESS=n
CONFIG_SOUND=n
CONFIG_DRM=n
CONFIG_USB=n
CONFIG_PCCARD=n
CONFIG_INPUT=n
CONFIG_HID=n
CONFIG_HWMON=n
CONFIG_IOMMU_SUPPORT=n
CONFIG_MODULES=n

# Debug (keep minimal)
CONFIG_PRINTK=y
CONFIG_EARLY_PRINTK=y
